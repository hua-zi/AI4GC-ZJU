# Optional: GitHub API token for higher rate limits when fetching repository star counts.
# GITHUB_TOKEN=

# --- Admin panel (local content/ writes) ---
# Dev: admin is enabled by default when NODE_ENV !== production.
ADMIN_PASSWORD=change-me-to-a-strong-password

# Production: set both to expose /admin online.
# ADMIN_ENABLED=true
# ADMIN_SECRET=use-a-long-random-secret-different-from-password

# Optional: restrict admin to trusted IPs (comma-separated)
# ADMIN_ALLOWED_IPS=203.0.113.10
